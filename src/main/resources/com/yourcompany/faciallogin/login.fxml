<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.yourcompany.faciallogin.LoginController">
   <children>
      <Label text="Facial Login System">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <ImageView fx:id="cameraView" fitHeight="400.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true" />
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Name/ID:" />
            <TextField fx:id="nameField" promptText="Enter your name" />
         </children>
      </HBox>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button fx:id="enrollButton" onAction="#handleEnrollButton" text="Enroll New User" />
            <Button fx:id="loginButton" onAction="#handleLoginButton" text="Login" />
         </children>
      </HBox>
      <Label fx:id="statusLabel" text="Status: Ready">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
